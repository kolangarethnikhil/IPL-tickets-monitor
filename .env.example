# ─────────────────────────────────────────────────────────────────
#  IPL Ticket Alert Bot — Environment Variables
#  Copy this to .env and fill in your values.
#  NEVER commit .env to GitHub!
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstUVwXyZ
TELEGRAM_CHAT_ID=987654321

# ── OPTIONAL ──────────────────────────────────────────────────────

# City for BookMyShow fallback (default: bangalore)
CITY=bangalore

# How often to check in seconds (default: 90)
# RCB matches sell fast — keep this low!
CHECK_INTERVAL_SECONDS=90

# Heartbeat every N checks (default: 40 = every ~1 hour at 90s interval)
HEARTBEAT_EVERY_N_CHECKS=40

# Don't re-alert same match within this many seconds (default: 3600)
ALERT_COOLDOWN_SECONDS=3600

# Log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
